# ──────────────────────────────────────────────
# DevForge Root .gitignore
# ──────────────────────────────────────────────

# ── Dependencies ──────────────────────────────
node_modules/

# ── Build output ──────────────────────────────
dist/
dist-ssr/
*.tsbuildinfo

# ── Environment / Secrets ─────────────────────
.env
.env.*
!.env.example

# ── IDE / Editor ──────────────────────────────
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.code-workspace

# ── OS generated ──────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini
._*

# ── Logs ──────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── Dev screenshots / images (artifacts) ──────
*.png
*.jpg
*.jpeg

# ── Archives ──────────────────────────────────
*.rar
*.zip
*.tar.gz
*.7z

# ── Reference repos ──────────────────────────
S10P31A709/

# ── Jenkins workspace ─────────────────────────
jenkins_home/

# ── AI agent workspace ────────────────────────
.sisyphus/
.opencode/

# ── Test artifacts ────────────────────────────
frontend/test-results/
frontend/playwright-report/
frontend/test-*.js
frontend/test-*.tsx
frontend/test-*.cjs
frontend/prep.ts

# ── Misc assets (local only) ─────────────────
assets/

 # ── Duplicate model files ─────────────────────
pokeball/

# ── Debug text logs ───────────────────────────
console-log.txt

# ── Backend build artifacts ──────────────────
backend/.gradle/
backend/.classpath
backend/.factorypath
