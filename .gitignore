# ──────────────────────────────────────────────
# DevForge Root .gitignore
# ──────────────────────────────────────────────

# ── Dependencies ──────────────────────────────
node_modules/

# ── Build output ──────────────────────────────
dist/
dist-ssr/
*.tsbuildinfo

# ── Environment / Secrets ─────────────────────
.env
.env.*
!.env.example

# ── IDE / Editor ──────────────────────────────
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.code-workspace

# ── OS generated ──────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini
._*

# ── Logs ──────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── Dev screenshots / images (artifacts) ──────
*.png
*.jpg
*.jpeg

# ── Archives ──────────────────────────────────
*.rar
*.zip
*.tar.gz
*.7z

# ── Reference repos ──────────────────────────
S10P31A709/

# ── Jenkins workspace ─────────────────────────
jenkins_home/

# ── AI agent workspace ────────────────────────
.sisyphus/

# ── Test artifacts ────────────────────────────
pokemon-prop-hunt/test-results/
pokemon-prop-hunt/playwright-report/
pokemon-prop-hunt/test-*.js
pokemon-prop-hunt/test-*.tsx
pokemon-prop-hunt/test-*.cjs
pokemon-prop-hunt/prep.ts

# ── Misc assets (local only) ─────────────────
assets/
